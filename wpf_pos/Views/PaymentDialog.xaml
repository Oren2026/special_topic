<Window x:Class="WPF_POS.Views.PaymentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="結帳" Height="380" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#2D2D30">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 金額顯示 -->
        <TextBlock Grid.Row="0" Text="結帳金額" FontSize="14" Foreground="#9E9E9E"/>
        <TextBlock Grid.Row="1" FontSize="36" FontWeight="Bold" Foreground="#4CAF50" Margin="0,4,0,20">
            <Run Text="$"/><Run x:Name="TotalText" Text="0"/>
        </TextBlock>

        <!-- 付款方式 -->
        <TextBlock Grid.Row="2" Text="付款方式" FontSize="14" Foreground="#9E9E9E" Margin="0,0,0,8"/>
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,16">
            <RadioButton x:Name="CashRadio" Content="現金" IsChecked="True" Foreground="White"
                         Checked="PaymentMethod_Changed" Margin="0,0,20,0"/>
            <RadioButton x:Name="CardRadio" Content="信用卡" Foreground="White"
                         Checked="PaymentMethod_Changed"/>
        </StackPanel>

        <!-- 收款金額（現金模式） -->
        <StackPanel Grid.Row="4" x:Name="CashPanel">
            <TextBlock Text="收款金額" FontSize="14" Foreground="#9E9E9E" Margin="0,0,0,4"/>
            <TextBox x:Name="PaidBox" Padding="8,6" FontSize="16" Background="#3E3E42"
                     Foreground="White" BorderThickness="0" TextChanged="PaidBox_TextChanged"/>
        </StackPanel>

        <!-- 找零（現金模式） -->
        <StackPanel Grid.Row="5" x:Name="ChangePanel" Margin="0,12,0,0">
            <TextBlock Text="找零" FontSize="14" Foreground="#9E9E9E"/>
            <TextBlock x:Name="ChangeText" FontSize="24" FontWeight="Bold" Foreground="#FF9800">$0</TextBlock>
        </StackPanel>

        <!-- 按鈕 -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="取消" Width="100" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button x:Name="ConfirmBtn" Content="確認收款" Width="120" Style="{StaticResource PrimaryButton}" Click="Confirm_Click"/>
        </StackPanel>
    </Grid>
</Window>