<UserControl x:Class="WPF_POS.Views.TagManagementControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="🏷️ 標籤管理" FontSize="20" FontWeight="Bold"/>
            <Button Content="+ 新增標籤" HorizontalAlignment="Right"
                    Style="{StaticResource PrimaryButton}"
                    Click="AddTag_Click"/>
        </Grid>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding FilteredTags}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Background="Transparent"
                  RowBackground="#3E3E42"
                  AlternatingRowBackground="#4E4E52"
                  GridLinesVisibility="None"
                  HeadersVisibility="Column"
                  BorderThickness="0">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                <DataGridTextColumn Header="名稱" Binding="{Binding Name}" Width="*"/>
                <DataGridTemplateColumn Header="顏色" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Width="60" Height="24" CornerRadius="4">
                                <Border.Background>
                                    <SolidColorBrush Color="{Binding Color}"/>
                                </Border.Background>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="操作" Width="160">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="編輯" Margin="0,0,8,0" Click="EditTag_Click" Tag="{Binding}"/>
                                <Button Content="刪除" Style="{StaticResource DangerButton}" Click="DeleteTag_Click" Tag="{Binding}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>